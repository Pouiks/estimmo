# ============================================================
# ESTIMMO - variables d'environnement
# Copier en .env.local pour le développement.
# ============================================================

# --- Supabase (Dashboard → Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Chaîne Postgres directe (Dashboard → Connect → Session pooler, port 5432).
# Utilisée UNIQUEMENT par les scripts locaux (migrations, imports DVF/ANIL),
# jamais par l'app Vercel.
SUPABASE_DB_URL=postgresql://postgres.xxxx:MOT_DE_PASSE@aws-0-eu-west-3.pooler.supabase.com:5432/postgres

# --- Email transactionnel (Resend) ---
# Sans RESEND_API_KEY / EMAIL_FROM : les emails sont simulés (affichés en console).
# EMAIL_FROM doit pointer sur un domaine vérifié dans Resend.
RESEND_API_KEY=
EMAIL_FROM="Carenza Brown <no-reply@earlypanel.fr>"

# --- CRM externe ---
# Si absent en développement : la synchro reste en file (status pending).
CRM_WEBHOOK_URL=
CRM_API_KEY=

# --- Sécurité cron Vercel (Authorization: Bearer <CRON_SECRET>) ---
CRON_SECRET=

# --- Notifications internes (nouveau lead) ---
ADMIN_NOTIFICATION_EMAIL=browncarenza@gmail.com

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
